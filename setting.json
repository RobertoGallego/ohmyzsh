{
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "typescript.updateImportsOnFileMove.enabled": "never",
  "javascript.updateImportsOnFileMove.enabled": "never",
  "color-highlight.languages": ["*"],
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "editor.suggestSelection": "first",
  "files.exclude": {
    "**/.classpath": true,
    "**/.project": true,
    "**/.settings": true,
    "**/.factorypath": true,
  },
  "workbench.editorAssociations": {
    "*.ipynb": "jupyter-notebook",
    "*.md": "vscode.markdown.preview.editor",
  },
  "terminal.integrated.tabs.location": "left",
  "editor.detectIndentation": false,
  "workbench.colorCustomizations": {
    "list.activeSelectionBackground": "#43424f",

    "sideBar.foreground": "#ffffff",
    "sideBarSectionHeader.foreground": "#ffffff",
    "focusBorder": "#11111b",
    "tab.activeBorder": "#101010",

    "tab.unfocusedHoverForeground": "#515670",
    "tab.inactiveForeground": "#515670",
    "tab.activeForeground": "#a9b1d6",
    "tab.hoverForeground": "#515670",
    "tab.unfocusedInactiveForeground": "#515670",
    "tab.unfocusedActiveForeground": "#515670",

    "gitDecoration.ignoredResourceForeground": "#dbc978",

    "editor.findMatchHighlightBackground": "#384D5D80",
    "editor.selectionBackground": "#384D5D",
    "editor.findMatchBackground": "#384D5D",

    "editorOverviewRuler.warningForeground": "#1e1e2e",
    "editorOverviewRuler.infoForeground": "#1e1e2e",
    "editorOverviewRuler.info": "#1e1e2e",
    "editorOverviewRuler.warning": "#1e1e2e",
    "editorOverviewRuler.background": "#1e1e2e",
    "editorOverviewRuler.border": "#1e1e2e",

    "titleBar.activeForeground": "#11111b",
    "titleBar.inactiveForeground": "#11111b",
    // "sideBarTitle.background": "#11111b",
    "sideBarTitle.foreground": "#11111b",

    "scrollbarSlider.background": "#313244",
    "scrollbarSlider.hoverBackground": "#45475a",
    "scrollbarSlider.activeBackground": "#45475a",

    "scrollbar.shadow": "#00000000",
    "editorIndentGuide.background1": "#313244",
    "editorIndentGuide.activeBackground1": "#45475a",
  },
  // "editor.lineNumbers": "off",

  "bracketPairColorizer.depreciation-notice": false,
  "workbench.sideBar.location": "right",
  "react-native-tools.showUserTips": false,

  "color-highlight.rgbWithNoFunctionLanguages": ["*"],

  "[python]": {
    "editor.formatOnType": true,
    "editor.defaultFormatter": "ms-python.autopep8",
  },
  "material-icon-theme.activeIconPack": "react",
  "json.schemas": [],
  "editor.rulers": [],
  "CodeGPT.model": "gpt-4",
  "github.copilot.enable": {
    "*": true,
    "plaintext": false,
    "markdown": false,
    "scminput": false,
    "yaml": false,
    "typescriptreact": true,
    "typescript": true,
    "python": true,
    "dotenv": true
  },
  "terminal.integrated.tabs.enabled": false,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontVariations": false,
  "editor.letterSpacing": 0.5,
  "editor.fontFamily": "JetBrains Mono,'JetBrainsMono Nerd Font Mono', Space Mono, iberation Mono, monospace",
  "editor.lineHeight": 1.1,
  "editor.fontLigatures": false,
  "security.workspace.trust.startupPrompt": "always",
  "gitlens.showWelcomeOnInstall": false,
  "workbench.startupEditor": "none",
  "workbench.tips.enabled": false,
  "terminal.integrated.commandsToSkipShell": [
    "workbench.action.toggleSidebarVisibility",
  ],
  "liveSassCompile.settings.includeItems": [],
  "gitlens.currentLine.format": "${author, }${agoOrDate}${' via 'pullRequest}",
  "gitlens.currentLine.dateFormat": "",
  "gitlens.codeLens.authors.enabled": false,
  "gitlens.codeLens.recentChange.enabled": false,
  "gitlens.blame.format": "${author|15?}${agoOrDate|14-}",

  "github.copilot.advanced": {},
  "editor.linkedEditing": true,
  "editor.cursorWidth": 10,
  "editor.find.cursorMoveOnType": false,
  "editor.quickSuggestions": {
    "other": "off",
  },
  "editor.parameterHints.enabled": false,
  // "editor.renderLineHighlight": "gutter",

  "window.title": "\"\"",
  "window.titleBarStyle": "custom",
//   "breadcrumbs.enabled": false,
  "breadcrumbs.symbolPath": "off",
//   "breadcrumbs.filePath": "last",
  "breadcrumbs.icons": false,
  "editor.wordWrap": "on",
  "diffEditor.ignoreTrimWhitespace": false,
  "workbench.editor.empty.hint": "hidden",
  "material-icon-theme.folders.theme": "specific",
  "editor.scrollbar.horizontalScrollbarSize": 6,
  "editor.scrollbar.verticalScrollbarSize": 6,
  "editor.smoothScrolling": true,
  "gitlens.heatmap.hotColor": "",
  "workbench.editor.doubleClickTabToToggleEditorGroupSizes": "off",
  "codesnap.realLineNumbers": true,
  "emmet.preferences": {},
  "editor.lightbulb.enabled": "off",
  "cSpell.userWords": ["organisation", "xmark", "xsmall", "zustand"],
  "editor.stickyScroll.enabled": false,
  "vsintellicode.modify.editor.suggestSelection": "automaticallyOverrodeDefaultValue",
  "editor.suggestOnTriggerCharacters": false,
  "sonarlint.rules": {
    "typescript:S125": {
      "level": "off",
    },
    "typescript:S6606": {
      "level": "off",
    },
  },
  "scm.showOutgoingChanges": "always",
  "gitlens.views.commits.showBranchComparison": false,
  "gitlens.views.showRelativeDateMarkers": false,
  "gitlens.views.commits.pullRequests.showForBranches": false,
  "gitlens.views.commits.pullRequests.enabled": false,
  "gitlens.views.commits.avatars": false,
  "workbench.editor.enablePreviewFromQuickOpen": false,
  "tailwindCSS.files.exclude": ["**/.git/**", "**/.hg/**", "**/.svn/**"],
  "search.exclude": {
    "**/node_modules": false,
  },
  "explorer.autoRevealExclude": {
    "**/node_modules": false,
  },
  "terminal.sourceControlRepositoriesKind": "both",
  "scm.showActionButton": false,
  "scm.showIncomingChanges": "always",
  "symbols.hidesExplorerArrows": false,
  "prettier.semi": false,
  "window.menuBarVisibility": "compact",
  "explorer.confirmPasteNative": false,
  "prisma.showPrismaDataPlatformNotification": false,
  "editor.mouseWheelScrollSensitivity": 3,
  "workbench.colorTheme": "Tokyo Night",
  "editor.screenReaderAnnounceInlineSuggestion": false,
  "eslint.codeActionsOnSave.rules": null,
  "workbench.layoutControl.enabled": false,
  "window.commandCenter": false,
  "vsicons.dontShowNewVersionMessage": true,
  "glassit.alpha": 255,
  "editor.minimap.enabled": false,
  "color-highlight.markRuler": false,
  "editor.hideCursorInOverviewRuler": true,
  "git.ignoreMissingGitWarning": true,
  "git.showActionButton": {
    "commit": false,
    "sync": false,
    "publish": false,
  },
  "scm.diffDecorationsGutterPattern": {
    "modified": false,
  },
  "scm.diffDecorations": "none",
  "scm.alwaysShowActions": false,
  "editor.selectionHighlight": false,
  "editor.renderWhitespace": "none",
  "editor.matchBrackets": "never",
  "git.decorations.enabled": false,
  "explorer.compactFolders": false,
  "editor.glyphMargin": false,
  "git.enableStatusBarSync": false,
  "workbench.iconTheme": "gruvbox-material-icon-theme",
  "terminal.integrated.fontFamily": "Mononoki Nerd Font",
  "terminal.integrated.fontSize": 13,
  "vscode_custom_css.imports": ["file:///Users/rvgallego/.custom-vscode.css"],
  "security.workspace.trust.untrustedFiles": "open",
  "git.showCommitInput": false,
  "terminal.integrated.shellIntegration.enabled": false,
  "inlineChat.lineNaturalLanguageHint": false,
  "python.languageServer": "Pylance",
  "python.analysis.autoSearchPaths": true,
  "python.analysis.extraPaths": ["/Users/rvgallego/Reve/nuspir/backend"],
  // "python.analysis.completeFunctionParens": true,
  "python.analysis.autoImportCompletions": true,
  "terminal.external.osxExec": "iTerm.app",
  "github.copilot.nextEditSuggestions.enabled": true,
  "redhat.telemetry.enabled": true,
  "[go]": {
    "editor.defaultFormatter": "golang.go",
    "editor.formatOnSave": false,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "never",
    },
  },
  "workbench.editor.tabSizing": "shrink",
  "editor.fontSize": 13,
  "window.density.editorTabHeight": "compact",
  "css.completion.completePropertyWithSemicolon": false,
  "css.completion.triggerPropertyValueCompletion": true,
  "docker.extension.enableComposeLanguageServer": false,
  "workbench.editor.tabActionCloseVisibility": false,
  "markdown.preview.openMarkdownLinks": "inEditor",
  "chat.viewSessions.orientation": "stacked",
  "workbench.statusBar.visible": false
}
